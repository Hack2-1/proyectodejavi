# Sistema de Gestión de Servicios Bash - .gitignore

# ============================================================================
# LOGS Y REPORTES (no versionados)
# ============================================================================
*.log
/var/log/
/var/log/sistema-servicios/
/var/log/reportes/
*.txt.log

# ============================================================================
# ARCHIVOS TEMPORALES
# ============================================================================
*.tmp
*.temp
*~
.swp
.swo
*.bak
*.backup
*.zip

# ============================================================================
# DIRECTORIOS DE DATOS SENSIBLES
# ============================================================================
/var/backups/
/var/backups/sistema-servicios/
backup/
backups/
respaldos/
inventarios/
.local/state/sistema-servicios/
.config/sistema-servicios/

# ============================================================================
# CREDENCIALES Y TOKENS (IMPORTANTE)
# ============================================================================
# No versionamos tokens reales de Telegram
config.local.txt
config.prod.txt
.env
.env.local
*.secret
credentials.*
telegram.env

# ============================================================================
# DIRECTORIOS DE INSTALACIÓN
# ============================================================================
/opt/sistema-servicios/
/opt/

# ============================================================================
# ARCHIVOS DEL SISTEMA
# ============================================================================
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
*.iml

# ============================================================================
# REPORTES Y SALIDAS TEMPORALES
# ============================================================================
reporte_*.txt
remoto_*.txt
inventario_*.txt
test_results/
*.html
*.pdf
!MANUAL_TECNICO.pdf
!PRESENTACION_FINAL.pdf
*.xlsx

# ============================================================================
# ARCHIVOS DE IDE
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ============================================================================
# GIT
# ============================================================================
.git/
.gitattributes

# ============================================================================
# NODE/NPM (si se agrega en futuro)
# ============================================================================
node_modules/
npm-debug.log
package-lock.json

# ============================================================================
# PYTHON (si se agrega en futuro)
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# ============================================================================
# DOCKER (si se agrega en futuro)
# ============================================================================
.dockerignore
Dockerfile

# Excepciones - archivos que SÍ versionamos aunque normalmente se ignoran
!.gitkeep
!hosts.txt.example
!config.txt.example
